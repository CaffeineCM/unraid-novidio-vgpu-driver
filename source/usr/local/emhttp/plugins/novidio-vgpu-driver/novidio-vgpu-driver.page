<script>
function driverAction(form, action, title) {
    var version = encodeURIComponent(form.drv_version.value);
    var actionName = encodeURIComponent(action);
    openBox("/usr/local/emhttp/plugins/novidio-vgpu-driver/include/exec.sh&arg1=run_action&arg2="+actionName+"&arg3="+version,title,700,900,true);
    return false;
}

function uploadDriver(form) {
    var fileInput = form.driver_package;
    var status = $("#upload_status");
    var fileName = fileInput.value || "";

    if (!fileName) {
        status.css("color", "red").text("Select a driver package first.");
        return false;
    }

    if (!fileName.match(/\.txz$/i)) {
        status.css("color", "red").text("Only .txz driver packages are accepted.");
        return false;
    }

    var formData = new FormData();
    formData.append("action", "upload_driver");
    formData.append("driver_package", fileInput.files[0]);

    status.css("color", "#666").text("Uploading and validating package...");

    $.ajax({
        url: caURL,
        method: "POST",
        data: formData,
        processData: false,
        contentType: false,
        success: function(response) {
            var result = response;
            if (typeof response === "string") {
                result = JSON.parse(response);
            }
            if (result.success) {
                status.css("color", "green").text(result.message + " Refreshing versions...");
                window.setTimeout(function() { window.location.reload(); }, 1200);
            } else {
                status.css("color", "red").text(result.message || "Upload failed.");
            }
        },
        error: function(xhr) {
            var result = {};
            try {
                result = JSON.parse(xhr.responseText);
            } catch (err) {}
            status.css("color", "red").text(result.message || "Upload failed.");
        }
    });

    return false;
}

function viewDriverLog() {
    $.get(caURL, {action: "get_driver_log"}, function(data) {
        $("#driver_log_contents").text(data || "No driver log found yet.");
        $("#driver_log_modal").show();
    });
    return false;
}

function downloadDriverLog() {
    window.location = caURL + "?action=download_driver_log";
    return false;
}

function closeDriverLog() {
    $("#driver_log_modal").hide();
    return false;
}
</script>

